#!/bin/bash
set -e

REPO_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

# ─── Resolve data directory ────────────────────────────────────────────────────
# Priority: env var > config.json > default
if [ -n "$GROCERY_DATA_DIR" ]; then
    DATA_DIR="$GROCERY_DATA_DIR"
elif [ -f "$HOME/.grocery-receipts/config.json" ]; then
    DATA_DIR=$(python3 -c "import json; print(json.load(open('$HOME/.grocery-receipts/config.json'))['dataDir'])" 2>/dev/null || echo "$HOME/.grocery-receipts")
else
    DATA_DIR="$HOME/.grocery-receipts"
fi

RECEIPTS_DIR="$DATA_DIR/receipts"
IMAGES_DIR="$RECEIPTS_DIR/images"
DB_PATH="$DATA_DIR/db/groceries.db"

# ─── Usage ─────────────────────────────────────────────────────────────────────
if [ $# -lt 1 ]; then
    echo "Usage: parse-receipt <image_path>"
    echo ""
    echo "Parse a grocery receipt image and store the data."
    echo ""
    echo "Options:"
    echo "  GROCERY_DATA_DIR=/path  Override data directory"
    echo ""
    echo "Examples:"
    echo "  parse-receipt photo.jpg"
    echo "  parse-receipt ~/Downloads/costco-receipt.jpg"
    echo "  GROCERY_DATA_DIR=/external/drive parse-receipt photo.jpg"
    exit 1
fi

IMAGE_PATH="$1"

if [ ! -f "$IMAGE_PATH" ]; then
    echo "❌ Image not found: $IMAGE_PATH"
    exit 1
fi

# ─── Ensure directories exist ──────────────────────────────────────────────────
mkdir -p "$IMAGES_DIR"
mkdir -p "$DATA_DIR/db"

# ─── Generate receipt ID ───────────────────────────────────────────────────────
RECEIPT_ID="$(date +%Y%m%d)-$(uuidgen | tr '[:upper:]' '[:lower:]' | cut -d- -f1)"

echo "📸 Processing receipt: $RECEIPT_ID"

# ─── Save image ────────────────────────────────────────────────────────────────
cp "$IMAGE_PATH" "$IMAGES_DIR/$RECEIPT_ID.jpg"
echo "✅ Image saved"

# ─── Preprocess ────────────────────────────────────────────────────────────────
if command -v magick &> /dev/null; then
    magick "$IMAGES_DIR/$RECEIPT_ID.jpg" -auto-orient -colorspace Gray -contrast-stretch 0 -sharpen 0x1 "/tmp/$RECEIPT_ID-pre.jpg"
    OCR_IMAGE="/tmp/$RECEIPT_ID-pre.jpg"
elif command -v convert &> /dev/null; then
    convert "$IMAGES_DIR/$RECEIPT_ID.jpg" -auto-orient -colorspace Gray -contrast-stretch 0 "/tmp/$RECEIPT_ID-pre.jpg"
    OCR_IMAGE="/tmp/$RECEIPT_ID-pre.jpg"
else
    OCR_IMAGE="$IMAGES_DIR/$RECEIPT_ID.jpg"
fi

# ─── OCR ───────────────────────────────────────────────────────────────────────
echo "🔍 Running OCR..."
python3 "$REPO_DIR/scripts/ocr-tesseract.py" "$OCR_IMAGE" > "/tmp/$RECEIPT_ID-ocr.json"
CONFIDENCE=$(python3 -c "import json; print(json.load(open('/tmp/$RECEIPT_ID-ocr.json'))['confidence'])")
echo "📊 Confidence: $CONFIDENCE"

# TODO: EasyOCR fallback (confidence < 0.7)
# TODO: Claude Vision fallback (confidence < 0.7)

echo ""
echo "⚠️  OCR parser not yet built — raw text saved to: /tmp/$RECEIPT_ID-ocr.json"
echo "    Run 'cat /tmp/$RECEIPT_ID-ocr.json' to inspect output."
