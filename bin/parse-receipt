#!/bin/bash
set -e

REPO_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
DATA_DIR="$HOME/.grocery-receipts"
RECEIPTS_DIR="$DATA_DIR/receipts"
IMAGES_DIR="$RECEIPTS_DIR/images"

# Usage
if [ $# -lt 1 ]; then
    echo "Usage: parse-receipt <image_path>"
    echo ""
    echo "Parse a grocery receipt image and store the data."
    echo ""
    echo "Examples:"
    echo "  parse-receipt photo.jpg"
    echo "  parse-receipt ~/Downloads/costco-receipt.jpg"
    exit 1
fi

IMAGE_PATH="$1"

if [ ! -f "$IMAGE_PATH" ]; then
    echo "Error: Image not found: $IMAGE_PATH"
    exit 1
fi

# Generate receipt ID
RECEIPT_ID="$(date +%Y%m%d)-$(uuidgen | tr '[:upper:]' '[:lower:]' | cut -d- -f1)"

echo "📸 Processing receipt..."

# 1. Copy image to data directory
cp "$IMAGE_PATH" "$IMAGES_DIR/$RECEIPT_ID.jpg"
echo "✅ Image saved: $IMAGES_DIR/$RECEIPT_ID.jpg"

# 2. Preprocess (optional, improve OCR quality)
if command -v magick &> /dev/null; then
    magick "$IMAGES_DIR/$RECEIPT_ID.jpg" -auto-orient -colorspace Gray -contrast-stretch 0 -sharpen 0x1 "/tmp/$RECEIPT_ID-preprocessed.jpg"
    OCR_IMAGE="/tmp/$RECEIPT_ID-preprocessed.jpg"
else
    OCR_IMAGE="$IMAGES_DIR/$RECEIPT_ID.jpg"
fi

# 3. Run OCR (Tesseract)
echo "🔍 Running OCR..."
python3 "$REPO_DIR/scripts/ocr-tesseract.py" "$OCR_IMAGE" > "/tmp/$RECEIPT_ID-ocr.json"

CONFIDENCE=$(jq -r '.confidence' "/tmp/$RECEIPT_ID-ocr.json")
echo "📊 OCR Confidence: $CONFIDENCE"

# TODO: Add EasyOCR fallback if confidence < 0.7
# TODO: Add Claude Vision fallback if confidence < 0.7

# 4. Parse OCR output (TODO: build actual parser)
# For now, we'll need manual structured data
if [ "$CONFIDENCE" = "null" ] || [ "$(echo "$CONFIDENCE < 0.7" | bc -l)" = "1" ]; then
    echo "⚠️  Low OCR confidence. Manual review recommended."
    echo "    Raw OCR saved to: /tmp/$RECEIPT_ID-ocr.json"
    echo ""
    echo "    To continue, create structured JSON at: /tmp/$RECEIPT_ID-structured.json"
    echo "    Then run: grocery-import $RECEIPT_ID /tmp/$RECEIPT_ID-structured.json"
    exit 0
fi

echo "✅ Receipt parsed: $RECEIPT_ID"
echo "📄 Next: Build parser to extract structured data from OCR"
